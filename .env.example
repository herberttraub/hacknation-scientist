# LLM provider — "gemini" or "openai"
LLM_PROVIDER=gemini

# Keys (one is required, matching LLM_PROVIDER above)
OPENAI_KEY=
GEMINI_KEY=

# Model names (sensible defaults; override only if needed)
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

OPENAI_MODEL_PRO=gpt-4.1
OPENAI_MODEL_FLASH=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# Postgres + pgvector (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://scientist:scientist@localhost:5432/scientist

# QC tunables
NOVELTY_THRESHOLD=0.72

# Demo safety — when true, serve cached outputs for the 4 sample inputs
DEMO_MODE=false

# Frontend → backend
NEXT_PUBLIC_API_BASE=http://localhost:8765
API_PORT=8765

# Semantic Scholar (optional; works without a key but rate-limited)
SEMANTIC_SCHOLAR_KEY=
